# Copy this file to .env and fill in the values.
#   cp .env.example .env

# ── Ethereum node ────────────────────────────────────────────────────────────
# Local Ganache (docker-compose): http://localhost:8545
# Override to any EVM-compatible RPC endpoint for production.
ETH_NODE_URL=http://localhost:8545
ETH_CHAIN_ID=1337

# Private key of the account that signs anchoring transactions.
# When using Ganache with the mnemonic in docker-compose.yml, account #0 key:
ETH_PRIVATE_KEY=0xdce368029c632b3761112754bf94474002fe2e631718b92fa66644f212ce7b67
